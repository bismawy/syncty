{"name": "syncty", "version": "0.1.0", "private": true, "description": "Syncty — bookmark sync extension (zero-knowledge E2E) for Chromium & Firefox.", "workspaces": ["extension", "backend"], "scripts": {"dev:ext": "npm run dev -w extension", "dev:api": "npm run dev -w backend", "dev": "concurrently -n ext,api -c blue,green \"npm:dev:ext\" \"npm:dev:api\"", "build:ext": "npm run build -w extension", "build:api": "npm run build -w backend", "zip:ext": "npm run zip -w extension", "deploy:api": "npm run deploy -w backend", "typecheck": "npm run typecheck -w extension && npm run typecheck -w backend"}, "devDependencies": {"concurrently": "^9.1.0"}}